# Required on Vercel (Production, Preview, and Development)
DATABASE_URL=file:./prisma/dev.db
INSFORGE_URL=https://your-project.insforge.app
INSFORGE_API_KEY=your-server-side-insforge-api-key
AUTH_SECRET=generate-a-long-random-secret
NEXT_PUBLIC_SITE_URL=https://your-domain.example
# Do not set NEXTAUTH_URL to a generated Vercel deployment URL. Auth.js uses
# the active request host so admin callbacks keep working after redeployments.

# Optional email delivery
RESEND_API_KEY=
EMAIL_FROM=

# Optional fallback admin credentials
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
ADMIN_NAME=
